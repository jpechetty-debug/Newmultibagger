# ─── Sovereign AI Trading Engine — Environment Variables ───────────────────
# Copy this file to .env and fill in every value marked REQUIRED.
# NEVER commit the real .env to source control.

# ── API Keys (REQUIRED — no fallback defaults) ──────────────────────────────
ALPHA_VANTAGE_API_KEY=           # Get free key at https://www.alphavantage.co/
OLLAMA_URL=http://localhost:11434/api/generate
MIROFISH_API_URL=http://localhost:5001/api  # Used for the multi-agent Swarm Intelligence layer
# ── Database ─────────────────────────────────────────────────────────────────
# Production: use PostgreSQL + TimescaleDB via docker-compose
DATABASE_URL=postgresql+psycopg://sovereign:sovereign_secret@localhost:5432/sovereign_db
# Local dev fallback (SQLite — single-process only)
# DATABASE_URL=sqlite:///./stocks.db

POSTGRES_PASSWORD=sovereign_secret

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_BACKEND=redis://localhost:6379/1

# ── FastAPI ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no wildcard in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9005
PORT=9005
DEBUG=false

# ── Cache TTLs (seconds) ─────────────────────────────────────────────────────
REGIME_CACHE_TTL_SECONDS=120
MOVERS_CACHE_TTL_SECONDS=120

# ── Risk Overrides ────────────────────────────────────────────────────────────
# Leave blank to use defaults from config.py
HARD_KILL_SWITCH_VIX=
FORCED_REGIME=          # Options: BULL | BEAR | SIDEWAYS | (blank = auto)
